{% extends 'base.html.twig' %}

{% block title %}Reminder{% endblock %}

{% block body %}
    <h1>Reminder</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ reminder.id }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ reminder.type }}</td>
            </tr>
            <tr>
                <th>Frequency</th>
                <td>{{ reminder.frequency }}</td>
            </tr>
            <tr>
                <th>Time</th>
                <td>{{ reminder.time ? reminder.time|date('H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_reminder_index') }}">back to list</a>

    <a href="{{ path('app_reminder_edit', {'id': reminder.id}) }}">edit</a>

    {{ include('reminder/_delete_form.html.twig') }}
{% endblock %}
