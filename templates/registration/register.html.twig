{% extends 'base.html.twig' %}
{% block title %}Register{% endblock %}
{% block body %}
<div class="h-screen flex flex-col overflow-hidden">
  {# Contenu principal #}
  <div class="flex-1 flex overflow-hidden">
    {# Colonne gauche : titre + mascotte #}
    <div class="flex-1 flex flex-col items-center justify-center bg-gray-50 gap-8">
      <h1 class="text-5xl font-black uppercase tracking-wider text-center leading-tight italic">
        <span class="text-[#48742C]">Créer</span>
        <span class="text-gray-900"> un </span>
        <span class="text-[#48742C]">compte</span>
      </h1>
      <img src="{{ asset('images/mascotte.png') }}" alt="mascotte" class="w-[65rem]">
    </div>

    {# Colonne droite : formulaire #}
    <div class="flex-1 flex items-center justify-center bg-gray-50 p-8">
      <div class="bg-white rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.15)] p-10 w-full max-w-md">

        {% for flash_error in app.flashes('verify_email_error') %}
          <div class="bg-red-100 text-red-700 rounded-lg px-4 py-3 mb-4 text-sm">
            {{ flash_error }}
          </div>
        {% endfor %}

        {{ form_errors(registrationForm) }}
        {{ form_start(registrationForm, {'attr': {'class': 'flex flex-col gap-4'}}) }}
          {{ form_row(registrationForm.name) }}
          {{ form_row(registrationForm.firstname) }}
          {{ form_row(registrationForm.email) }}
          {{ form_row(registrationForm.gender) }}
          {{ form_row(registrationForm.weight) }}
          {{ form_row(registrationForm.dateOfBirth) }}
          {{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}
          {{ form_row(registrationForm.agreeTerms) }}

          <button type="submit" class="w-full bg-blue-900 text-white font-semibold py-3 rounded-xl border-none cursor-pointer mt-2 text-base">
            Créer un compte
          </button>

          <a href="#" class="block text-center mt-3 text-sm text-[#48742C] underline">
            Mot de passe oublié ?
          </a>
        {{ form_end(registrationForm) }}
      </div>
    </div>
  </div>

  {# Bande verte horizontale en bas #}
  <div class="h-[12vh] bg-[#48742C] w-full flex-shrink-0"></div>
</div>
{% endblock %}