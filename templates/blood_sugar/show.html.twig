{% extends 'base.html.twig' %}

{% block title %}BloodSugar{% endblock %}

{% block body %}
    <h1>BloodSugar</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ blood_sugar.id }}</td>
            </tr>
            <tr>
                <th>Value</th>
                <td>{{ blood_sugar.value }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ blood_sugar.date ? blood_sugar.date|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Time</th>
                <td>{{ blood_sugar.time ? blood_sugar.time|date('H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_blood_sugar_index') }}">back to list</a>

    <a href="{{ path('app_blood_sugar_edit', {'id': blood_sugar.id}) }}">edit</a>

    {{ include('blood_sugar/_delete_form.html.twig') }}
{% endblock %}
