{% extends 'base.html.twig' %}
{% block title %}Log in!{% endblock %}
{% block body %}
<section class="h-screen flex flex-col overflow-hidden">
  {# Contenu principal centré #}
  <div class="flex-1 flex flex-col items-center justify-center bg-gray-50 gap-6">

 <a href="{{ path('app_home') }}">
  <img src="{{ asset('images/logo.png') }}" alt="logo" class="absolute top-6 left-6 w-[30rem] h-auto z-5">
</a>

    <h1 class="text-5xl font-black uppercase tracking-wider text-center leading-tight italic">
      <span class="text-gray-900">SE </span>
      <span class="text-[#48742C]">CONNECTER</span>
    </h1>

    <div class="bg-white rounded-2xl shadow-[0_20px_40px_rgba(0,0,0,0.15)] p-10 w-full max-w-md">
      <form method="post" class="flex flex-col gap-4">
        {% if error %}
          <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
          <div class="mb-3">
            Vous êtes connecté(e) en tant que {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Déconnexion</a>
          </div>
        {% endif %}

        <div class="flex flex-col gap-1">
          <label for="username">Email</label>
          <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control border rounded-lg px-3 py-2" autocomplete="username" required autofocus>
        </div>

        <div class="flex flex-col gap-1">
          <label for="password">Mot de passe</label>
          <input type="password" name="_password" id="password" class="form-control border rounded-lg px-3 py-2" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <div class="flex items-center gap-2">
          <input type="checkbox" name="_remember_me" id="_remember_me">
          <label for="_remember_me">Se souvenir de moi</label>
        </div>

        <button type="submit" class="w-full bg-blue-900 text-white font-semibold py-3 rounded-xl border-none cursor-pointer mt-2 text-base">
          Se connecter
        </button>

       <a href="{{ path('app_forgot_password_request') }}"
   class="block text-center mt-3 text-sm text-[#48742C] underline">
    Mot de passe oublié ?
</a>
      </form>
    </div>

  </div>

  {# Bande verte horizontale en bas #}
  {#<div class="h-[18vh] bg-[#48742C] w-full "></div>#}
</section>
{% endblock %}