{% extends 'base.html.twig' %}

{% block title %}Vérification{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-100">

    <div class="bg-white rounded-2xl shadow-xl p-10 w-full max-w-md">

        <h1 class="text-3xl font-bold text-center mb-8">
            Vérification de sécurité
        </h1>

        <form action="{{ path('2fa_login_check') }}" method="post">

            <label class="block mb-2 font-semibold">
                Code reçu par e-mail
            </label>

            <input
                type="text"
                name="_auth_code"
                maxlength="6"
                class="w-full border rounded-lg p-3 mb-6"
                placeholder="123456"
            >

            <button
                type="submit"
                class="w-full bg-[#1558A8] text-white rounded-xl py-3 font-semibold hover:bg-blue-800 transition"
            >
                Vérifier
            </button>

        </form>

    </div>

</div>
{% endblock %}